# Database (Railway Postgres provides this automatically)
DATABASE_URL=postgresql+asyncpg://reelsearch:password@db:5432/reelsearch

# OpenAI (Whisper transcription, GPT-4o vision/extraction, text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Auth — generate a strong random secret for production
JWT_SECRET_KEY=change-me-to-a-random-secret

# CORS — comma-separated origins (set to your frontend URL in production)
CORS_ORIGINS=http://localhost:3000

# App
APP_ENV=development
LOG_LEVEL=INFO
